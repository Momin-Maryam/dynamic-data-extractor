{
  "manifest_version": 3,
  "name": "Configurable Data Extractor",
  "version": "0.1.0",
  "description": "Extract structured data from any webpage using your own custom CSS selectors.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Configurable Data Extractor"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/extractor.js"]
    }
  ]
}